# ==========================================
# 🔒 SECURITY & SECRETS (CRITICAL)
# ==========================================
# Ignore all environment variable files
*.env
.env
.env.*
.env*.local
*.local

# Expo Application Services Config (Contains Build Secrets)
eas.json

# NPM Configuration (Can contain auth tokens)
.npmrc

# ==========================================
# 📦 DEPENDENCIES & BUILD ARTIFACTS
# ==========================================
node_modules/
dist/
dist-ssr/
web-build/

# Expo specific
.expo/
expo-env.d.ts

# ==========================================
# ⚡ SUPABASE SPECIFIC
# ==========================================
# Ignore temporary CLI state and branch data
supabase/.branches/
supabase/.temp/

# Ignore env files potentially generated in functions or snippets
supabase/functions/**/.env
supabase/snippets/.env

# ==========================================
# 📝 LOGS & DEBUGGING
# ==========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==========================================
# 💻 IDE & EDITOR FILES
# ==========================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db
Desktop.ini
*.GEMINI.MD
GEMINI.md
# ==========================================
# 🧪 TESTING & COVERAGE
# ==========================================
coverage/
__tests__/
*.spec.js
*.test.js

